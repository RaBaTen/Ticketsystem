{
  "openapi": "3.0.3",
  "info": {
    "title": "Ticket System",
    "description": "This is an API for a ticket management system.",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "ticket",
      "description": "Ticket management"
    }
  ],
  "paths": {
    "/tickets": {
      "post": {
        "tags": ["ticket"],
        "summary": "Create a new ticket",
        "description": "A user can create a new support ticket.",
        "operationId": "createTicket",
        "parameters": [
          {
            "name": "X-User",
            "in": "header",
            "required": true,
            "description": "Username of the current user",
            "schema": {
              "type": "string",
              "example": "user123"
            }
          }
        ],
        "requestBody": {
          "description": "Create a new ticket in the system",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TicketInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          }
        }
      },
      "get": {
        "tags": ["ticket"],
        "summary": "Get tickets",
        "description": "Admin gets all tickets. User gets only their own tickets.",
        "operationId": "getTickets",
        "parameters": [
          {
            "name": "X-User",
            "in": "header",
            "required": true,
            "description": "Username of the current user",
            "schema": {
              "type": "string",
              "example": "user123"
            }
          },
          {
            "name": "X-Role",
            "in": "header",
            "required": true,
            "description": "Role of the current user",
            "schema": {
              "type": "string",
              "enum": ["USER", "ADMIN"],
              "example": "USER"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Ticket"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tickets/{ticketId}": {
      "get": {
        "tags": ["ticket"],
        "summary": "Get a single ticket",
        "description": "Admin can retrieve any ticket. User can retrieve only their own ticket.",
        "operationId": "getTicketById",
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "description": "ID of the ticket to return",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "X-User",
            "in": "header",
            "required": true,
            "description": "Username of the current user",
            "schema": {
              "type": "string",
              "example": "user123"
            }
          },
          {
            "name": "X-Role",
            "in": "header",
            "required": true,
            "description": "Role of the current user",
            "schema": {
              "type": "string",
              "enum": ["USER", "ADMIN"],
              "example": "USER"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Ticket not found"
          }
        }
      },
      "put": {
        "tags": ["ticket"],
        "summary": "Update a ticket",
        "description": "Admin can update any ticket. A user can update only their own ticket.",
        "operationId": "updateTicket",
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "description": "ID of the ticket to update",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "X-User",
            "in": "header",
            "required": true,
            "description": "Username of the current user",
            "schema": {
              "type": "string",
              "example": "user123"
            }
          },
          {
            "name": "X-Role",
            "in": "header",
            "required": true,
            "description": "Role of the current user",
            "schema": {
              "type": "string",
              "enum": ["USER", "ADMIN"],
              "example": "ADMIN"
            }
          }
        ],
        "requestBody": {
          "description": "Update an existing ticket",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TicketUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Ticket not found"
          }
        }
      },
      "delete": {
        "tags": ["ticket"],
        "summary": "Delete a ticket",
        "description": "Admin can delete any ticket. A user can delete only their own ticket.",
        "operationId": "deleteTicket",
        "parameters": [
          {
            "name": "ticketId",
            "in": "path",
            "required": true,
            "description": "ID of the ticket to delete",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "X-User",
            "in": "header",
            "required": true,
            "description": "Username of the current user",
            "schema": {
              "type": "string",
              "example": "user123"
            }
          },
          {
            "name": "X-Role",
            "in": "header",
            "required": true,
            "description": "Role of the current user",
            "schema": {
              "type": "string",
              "enum": ["USER", "ADMIN"],
              "example": "ADMIN"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Ticket deleted successfully"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Ticket not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Ticket": {
        "type": "object",
        "required": ["id", "title", "description", "status", "createdBy"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Login issue"
          },
          "description": {
            "type": "string",
            "example": "I cannot log into my account."
          },
          "status": {
            "type": "string",
            "enum": ["Open", "In Progress", "Closed"],
            "example": "Open"
          },
          "createdBy": {
            "type": "string",
            "example": "user123"
          },
          "assignedTo": {
            "type": "string",
            "nullable": true,
            "example": "supportAgent1"
          }
        }
      },
      "TicketInput": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Login issue"
          },
          "description": {
            "type": "string",
            "example": "I cannot log into my account."
          }
        }
      },
      "TicketUpdate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Updated issue"
          },
          "description": {
            "type": "string",
            "example": "Updated description"
          },
          "status": {
            "type": "string",
            "enum": ["Open", "In Progress", "Closed"],
            "example": "In Progress"
          },
          "assignedTo": {
            "type": "string",
            "nullable": true,
            "example": "supportAgent1"
          }
        }
      }
    }
  }
}
